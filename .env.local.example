# URL of the bunker-api service used by the `/api/*` rewrite proxy and by
# SSR `apiRequest` calls. Default matches the bunker-api `.env.example`
# (`PORT=3000`). If that port is taken (e.g. by this Next.js dev server),
# pick a free one for the BE and update this var to match.
#
# The proxy preserves the `/api` prefix: browser `/api/auth/me` ends up at
# `${API_ORIGIN}/api/auth/me`, which is where bunker-api's controllers live
# (the BE uses `app.setGlobalPrefix('api')`).
#
# Deployment notes:
# - Local dev: copy this file to `.env.local` and adjust the port.
# - Vercel: set `API_ORIGIN` in Project Settings → Environment Variables for
#   each target (Production / Preview / Development). The value must point to
#   a publicly reachable bunker-api origin (https://...). The rewrite and
#   server-side `apiRequest` read it at runtime, so no rebuild is needed when
#   it changes.
API_ORIGIN=http://localhost:3000
